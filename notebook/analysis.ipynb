   "source": [
    "## 1. Data Loading and Overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    
import json
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load the data from the JSON file
with open("data.json", "r") as f:
    data = json.load(f)

print("Data loaded successfully!")
print("Keys available in the data:", data.keys())

# Display KPIs
print("\n--- Key Performance Indicators (KPIs) ---")
for kpi, value in data["kpis"].items():
    print(f"  {kpi.replace("_", " ").title()}: {value}")

# Convert daily data to DataFrame
daily_df = pd.DataFrame({
    "Date": pd.to_datetime(data["daily"]["dates"]),
    "Total Detections": data["daily"]["totals"],
    "Accuracy": data["daily"]["accuracy"],
    "Confidence": data["daily"]["confidence"]
})
daily_df = daily_df.set_index("Date")

print("\nDaily Data Head:\n", daily_df.head())
print("\nDaily Data Info:")
daily_df.info()

  ]
 },
