   "## 2. Monthly Trends"
  ]
 },
 {
  "cell_type": "code",
  "execution_count": null,
  "metadata": {},
  "outputs": [],
  "source": [
   "monthly_df = pd.DataFrame({\n    \"Month\": data[\"monthly\"][\"labels\"],\n    \"Total Detections\": data[\"monthly\"][\"totals\"],\n    \"Accuracy\": data[\"monthly\"][\"accuracy\"],\n    \"High Alerts\": data[\"monthly\"][\"high\"],\n    \"Medium Alerts\": data[\"monthly\"][\"medium\"],\n    \"Low Alerts\": data[\"monthly\"][\"low\"],\n    \"Avg Confidence\": data[\"monthly\"][\"avg_conf\"],\n    \"Avg Response Time (ms)\": data[\"monthly\"][\"avg_rt\"]\n})\nmonthly_df[\"Month\"] = pd.to_datetime(monthly_df[\"Month\"])\nmonthly_df = monthly_df.set_index(\"Month\")\n\nprint(\"Monthly Performance Summary:\\\n\", monthly_df)\n\nplt.figure(figsize=(12, 6))\nsns.lineplot(x=monthly_df.index, y=\"Total Detections\", data=monthly_df, marker=\"o\")\nplt.title(\"Monthly Detection Volume Trend\")\nplt.xlabel(\"Month\")\nplt.ylabel(\"Total Detections\")\nplt.grid(True)\nplt.show()\n\nplt.figure(figsize=(12, 6))\nsns.lineplot(x=monthly_df.index, y=\"Accuracy\", data=monthly_df, marker=\"o\", color=\"green\")\nplt.title(\"Monthly Detection Accuracy Trend\")\nplt.xlabel(\"Month\")\nplt.ylabel(\"Accuracy (%)\")\nplt.grid(True)\nplt.show()"
  ]
 }

