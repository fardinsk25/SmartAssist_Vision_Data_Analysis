  "source": [
   "objects_df = pd.DataFrame({\n    \"Object Class\": data[\"objects\"][\"labels\"],\n    \"Count\": data[\"objects\"][\"counts\"],\n    \"Avg Confidence\": data[\"objects\"][\"avg_conf\"],\n    \"Avg Response Time (ms)\": data[\"objects\"][\"avg_rt\"],\n    \"High Alerts\": data[\"objects\"][\"high_alerts\"]\n})\nobjects_df = objects_df.sort_values(by=\"Count\", ascending=False).reset_index(drop=True)\n\nprint(\"Top 10 Detected Object Classes:\\\n\", objects_df)\n\nplt.figure(figsize=(12, 7))\nsns.barplot(x=\"Count\", y=\"Object Class\", data=objects_df, palette=\"viridis\")\nplt.title(\"Detection Count by Object Class\")\nplt.xlabel(\"Count\")\nplt.ylabel(\"Object Class\")\nplt.grid(axis=\"x\")\nplt.show()\n\nplt.figure(figsize=(12, 7))\nsns.barplot(x=\"Avg Confidence\", y=\"Object Class\", data=objects_df.sort_values(by=\"Avg Confidence\", ascending=False), palette=\"magma\")\nplt.title(\"Average AI Confidence by Object Class\")\nplt.xlabel(\"Average Confidence\")\nplt.ylabel(\"Object Class\")\nplt.grid(axis=\"x\")\nplt.xlim(0.85, 1.0)\nplt.show()"
